entrypoint = "main.py"
modules = ["nodejs-20", "web", "python-3.10", "nix"]

audio = true

hidden = [".pythonlibs"]

[nix]
channel = "stable-25_05"
packages = ["SDL2", "SDL2_image", "SDL2_mixer", "SDL2_ttf", "fontconfig", "freetype", "libjpeg", "libpng", "pkg-config", "portmidi"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5900
externalPort = 80

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Minesweeper"

[[workflows.workflow]]
name = "Minesweeper"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "cloudrun"
run = ["sh", "-c", "main.py"]
